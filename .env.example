# OpenCode AI
# Run `opencode serve --port 4096` locally, then point the app at it.
# Default: http://127.0.0.1:4096
OPENCODE_URL=http://127.0.0.1:4096
# Optional basic auth (set OPENCODE_SERVER_PASSWORD on the opencode side)
# OPENCODE_USERNAME=opencode
# OPENCODE_PASSWORD=

# Stripe API Credentials
# Add your Stripe Account Secret Key to enable live Checkout redirect loops
STRIPE_SECRET_KEY=

# Optional: Add your Stripe Publishable Key for public references
VITE_STRIPE_PUBLISHABLE_KEY=
